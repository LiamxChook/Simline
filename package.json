{
  "name": "simline",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:ios": "pnpm dlx eas-cli@latest build --platform ios --profile production",
    "submit:ios": "pnpm dlx eas-cli@latest submit --platform ios --latest",
    "testflight": "pnpm dlx eas-cli@latest build --platform ios --profile production --auto-submit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "~55.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "^19.2.2",
    "babel-preset-expo": "~55.0.8",
    "typescript": "^5.9.3"
  }
}
